# obstack demo client environment.
# Copy to .env and fill in.

# Obstack's PUBLIC OTLP endpoint. For local dev with self-signed cert use:
#   DEMO_OBSTACK_ENDPOINT=https://localhost
# For production with a real domain:
#   DEMO_OBSTACK_ENDPOINT=https://obs.example.com
DEMO_OBSTACK_ENDPOINT=https://localhost

# HTTP Basic auth credentials (must match BASIC_AUTH_USER + the plaintext
# password used to generate obstack's BASIC_AUTH_HASH).
DEMO_BASIC_AUTH_USER=ingest
DEMO_BASIC_AUTH_PASSWORD=devpass

# Skip TLS cert verification. Set to true ONLY for local dev with
# DOMAIN=localhost (self-signed cert). Never in production.
DEMO_OBSTACK_INSECURE=true

# Auto-computed by scripts/demo-up.sh — leave empty here.
DEMO_OBSTACK_AUTH_HEADER=

# Demo frontend port on the host (browse the Astronomy Shop here).
DEMO_FRONTEND_PORT=8082
