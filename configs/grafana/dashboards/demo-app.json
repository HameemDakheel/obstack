{
  "title": "obstack · Astronomy Shop (demo)",
  "uid": "obstack-demo-app",
  "tags": ["obstack", "demo", "astronomy-shop", "opentelemetry-demo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "uid": "prometheus", "type": "prometheus" },
        "query": "label_values(traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\"}, service_name)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services emitting telemetry",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "count(count by (service_name) (traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\"}))", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 5 }, { "color": "green", "value": 10 }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total request rate (req/s)",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "sum(rate(traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\", span_kind=~\"SPAN_KIND_SERVER|SPAN_KIND_CONSUMER\"}[1m]))", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate (errors/s)",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "sum(rate(traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\", status_code=\"STATUS_CODE_ERROR\"}[5m]))", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error % of requests",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "(sum(rate(traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\", status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum(rate(traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\"}[5m])), 1)) * 100", "refId": "A" }],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p95 latency (all services)",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_namespace=\"opentelemetry-demo\"}[5m])))", "refId": "A" }],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request rate by service",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\", service_name=~\"$service\", span_kind=~\"SPAN_KIND_SERVER|SPAN_KIND_CONSUMER\"}[1m]))", "legendFormat": "{{service_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Error rate by service",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\", service_name=~\"$service\", status_code=\"STATUS_CODE_ERROR\"}[5m]))", "legendFormat": "{{service_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 80 } }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "p95 latency by service (ms)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{service_namespace=\"opentelemetry-demo\", service_name=~\"$service\"}[5m])))", "legendFormat": "{{service_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineInterpolation": "smooth" } }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "p99 latency by service (ms)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{service_namespace=\"opentelemetry-demo\", service_name=~\"$service\"}[5m])))", "legendFormat": "{{service_name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineInterpolation": "smooth" } }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Top 15 slowest spans (p95, last 5m)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{
        "expr": "topk(15, histogram_quantile(0.95, sum by (le, service_name, span_name) (rate(traces_span_metrics_duration_milliseconds_bucket{service_namespace=\"opentelemetry-demo\", service_name=~\"$service\"}[5m]))))",
        "instant": true,
        "format": "table",
        "refId": "A"
      }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "renameByName": { "service_name": "Service", "span_name": "Span", "Value": "p95 ms" } } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [{ "matcher": { "id": "byName", "options": "p95 ms" }, "properties": [{ "id": "unit", "value": "ms" }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }] }] }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Top 15 erroring spans (last 5m)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{
        "expr": "topk(15, sum by (service_name, span_name) (rate(traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\", service_name=~\"$service\", status_code=\"STATUS_CODE_ERROR\"}[5m])))",
        "instant": true,
        "format": "table",
        "refId": "A"
      }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "renameByName": { "service_name": "Service", "span_name": "Span", "Value": "errors/s" } } }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [{ "matcher": { "id": "byName", "options": "errors/s" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }] }] }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Span throughput by kind",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "targets": [{ "expr": "sum by (span_kind) (rate(traces_span_metrics_calls_total{service_namespace=\"opentelemetry-demo\", service_name=~\"$service\"}[1m]))", "legendFormat": "{{span_kind}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 13,
      "type": "logs",
      "title": "Demo logs (last 100)",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 7 },
      "datasource": { "uid": "victorialogs", "type": "victoriametrics-logs-datasource" },
      "targets": [{ "expr": "service.namespace:=\"opentelemetry-demo\" AND service.name:~\"$service\"", "refId": "A" }],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
