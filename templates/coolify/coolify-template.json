{
  "name": "OTel-jps",
  "slogan": "Production observability for your $20/month VPS — all 5 signals, one command",
  "description": "OpenTelemetry-native observability stack: Prometheus + VictoriaLogs + Tempo + Pyroscope + Grafana + OTel Collector + Caddy. ~310 MB idle. 4 dashboards and 12 alerts pre-loaded. Compatible with the official OpenTelemetry demo.",
  "type": "compose",
  "tags": ["observability", "monitoring", "opentelemetry", "grafana", "prometheus", "victorialogs", "tempo", "pyroscope"],
  "logo": "https://raw.githubusercontent.com/HameemDakheel/OTel-jps/main/assets/logo.png",
  "minimum_version": "4.0.0-beta.318",
  "documentation_url": "https://github.com/HameemDakheel/OTel-jps/blob/main/docs/deployment/coolify.md",
  "compose_file": "./docker-compose.yml",
  "envs": [
    {
      "key": "GRAFANA_ADMIN_USER",
      "value": "admin",
      "is_required": true,
      "is_build_time": false,
      "description": "Grafana login username"
    },
    {
      "key": "GRAFANA_ADMIN_PASSWORD",
      "generate_value": true,
      "is_required": true,
      "is_build_time": false,
      "description": "Grafana login password (auto-generated by Coolify)"
    },
    {
      "key": "BASIC_AUTH_USER",
      "value": "ingest",
      "is_required": true,
      "is_build_time": false,
      "description": "Username your apps use to authenticate to OTLP ingestion endpoints"
    },
    {
      "key": "BASIC_AUTH_HASH",
      "value": "",
      "is_required": true,
      "is_build_time": false,
      "description": "bcrypt hash of the OTLP ingestion password. Generate: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'"
    },
    {
      "key": "PROMETHEUS_RETENTION",
      "value": "7d",
      "is_required": false,
      "is_build_time": false,
      "description": "How long Prometheus keeps metrics"
    },
    {
      "key": "VICTORIALOGS_RETENTION",
      "value": "7d",
      "is_required": false,
      "is_build_time": false,
      "description": "How long VictoriaLogs keeps logs"
    },
    {
      "key": "TEMPO_RETENTION_HOURS",
      "value": "72",
      "is_required": false,
      "is_build_time": false,
      "description": "Tempo trace retention (hours)"
    },
    {
      "key": "PYROSCOPE_RETENTION_HOURS",
      "value": "336",
      "is_required": false,
      "is_build_time": false,
      "description": "Pyroscope profile retention (hours, default 14 d)"
    },
    {
      "key": "ALERT_WEBHOOK_URL",
      "value": "https://example.invalid/alert",
      "is_required": false,
      "is_build_time": false,
      "description": "Webhook for default alerts (Slack/Discord/PagerDuty)"
    }
  ]
}
